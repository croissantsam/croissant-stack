{
  "extends": "@workspace/config-typescript/react.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "electron.vite.config.ts",
    "prettier.config.js"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ]
    }
  }
}
