{
  "extends": "@workspace/config-typescript/react.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "electron.vite.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@main/*": ["./src/main/src/*"],
      "@preload/*": ["./src/preload/src/*"]
    }
  }
}
