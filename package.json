{
  "name": "croissant-stack",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint --ignore-path .oxlintignore .",
    "lint:fix": "oxlint --fix --ignore-path .oxlintignore .",
    "format": "oxfmt --check --ignore-path .oxlintignore",
    "format:fix": "oxfmt --ignore-path .oxlintignore .",
    "quality": "turbo quality",
    "quality:fix": "turbo quality:fix",
    "typecheck": "turbo typecheck",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "update-deps": "npx npm-check-updates -u -w --root && npm install",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@better-auth/core": "^1.6.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "arktype": "^2.2.0",
    "expo": "^55.0.17",
    "expo-router": "~55.0.13",
    "husky": "^9.1.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "6.0.3",
    "vite": "^8.0.10"
  },
  "overrides": {
    "@noble/ciphers": "2.2.0",
    "drizzle-orm": "^0.45.2",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.13.0"
}
