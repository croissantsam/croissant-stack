    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.6.0",
    "tsup": "^8.1.0",
    "typescript": "^6.0.3"
  }
}
