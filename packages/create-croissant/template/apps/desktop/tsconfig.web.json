{
  "extends": "@workspace/config-typescript/react.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    }
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx", "src/renderer/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
